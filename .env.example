# ── Server (Next.js API) environment ──────────────────────────────────────
# Copy to ".env" for local dev. In production set these in your host's
# environment variables (not committed).

# MySQL connection string: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local:   mysql://root@127.0.0.1:3306/delzotto
# Hosted:  e.g. a free MySQL from TiDB Cloud / Railway / Aiven (often needs ?sslaccept=strict)
DATABASE_URL="mysql://velzotto:velzotto%4013DS@195.35.6.136:3306/velzotto"

# Secret used to sign admin JWTs — use a long random string.
JWT_SECRET="change-me-to-a-long-random-secret"

# Initial admin account (created by `npm run seed`).
ADMIN_EMAIL="admin@delzotto.com"
ADMIN_PASSWORD="change-me"

# Origin allowed to call the API from the admin SPA.
# Local: http://localhost:5173   Production: your deployed admin URL.
ADMIN_ORIGIN="http://localhost:5173"

# Cloudinary image storage. Get this from your Cloudinary dashboard
# (Account Details → API Environment variable). Leave unset to use local-disk
# uploads instead. Either set CLOUDINARY_URL, or the three separate vars below.
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
